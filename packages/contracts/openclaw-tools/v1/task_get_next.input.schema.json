{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task_get_next.input.v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "assignee": { "type": "string", "enum": ["ai", "human"] },
    "status": {
      "type": "array",
      "items": { "type": "string", "enum": ["pending", "in_progress", "blocked", "done"] },
      "minItems": 1
    },
    "worker_id": { "type": "string", "minLength": 1 },
    "lease_seconds": { "type": "integer", "minimum": 1 }
  },
  "required": ["assignee", "status"]
}
