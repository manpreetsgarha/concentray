#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CLI_DIR="$REPO_ROOT/apps/cli"
PYTHON_BIN="${PYTHON_BIN:-$(command -v python3 || command -v python)}"

if [[ "${CONCENTRAY_USE_UV:-0}" == "1" ]]; then
  if ! command -v uv >/dev/null 2>&1; then
    echo "CONCENTRAY_USE_UV=1 was set, but uv was not found in PATH." >&2
    exit 1
  fi
  export UV_CACHE_DIR="${UV_CACHE_DIR:-$REPO_ROOT/.uv-cache}"
  exec uv run --directory "$CLI_DIR" concentray "$@"
fi

if [[ -z "${PYTHON_BIN}" ]]; then
  echo "python3 or python with CLI deps installed is required." >&2
  exit 1
fi

export PYTHONPATH="$CLI_DIR/src${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON_BIN" -m concentray_cli.main "$@"
