#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CLI_DIR="$REPO_ROOT/apps/cli"
PYTHON_BIN="${PYTHON_BIN:-$(command -v python3.11 || command -v python3)}"

if [[ -z "${PYTHON_BIN}" ]]; then
  echo "python3.11 or python3 is required." >&2
  exit 1
fi

export PYTHONPATH="$CLI_DIR/src${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON_BIN" -m concentray_cli.main "$@"
